# .env.example
# Your Google Gemini API Key. Do NOT prefix with VITE_.
GEMINI_API_KEY=

# Brevo (transactional email for signup verification). Get a key at
# app.brevo.com > SMTP & API > API Keys. Verify MAIL_FROM_EMAIL as a
# Single Sender in Brevo first (Senders, Domains & Dedicated IPs > Senders).
BREVO_API_KEY=
MAIL_FROM_EMAIL=insyte.startup@gmail.com
